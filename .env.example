# ---------------------------------------------------------------------------
# Client (build-time, PUBLIC — ends up in the JS bundle)
# ---------------------------------------------------------------------------
# Where the demo form POSTs. On Cloudflare Pages this is the bundled Function
# at functions/api/demo.ts. Leave blank locally and the form falls back to a
# mailto: link, so you can develop without a backend.
#   Production (set in Cloudflare Pages → Variables): /api/demo
VITE_DEMO_FORM_ENDPOINT=

# ---------------------------------------------------------------------------
# Server (Cloudflare Pages Function — NEVER exposed to the browser).
# Set these in Cloudflare Pages → Settings → Variables and Secrets.
# Listed here for reference only; do not commit real values.
# ---------------------------------------------------------------------------
# RESEND_API_KEY=re_...                 # secret — resend.com/api-keys
# DEMO_TO_EMAIL=you@example.com         # where demo requests land
# DEMO_FROM_EMAIL=Kukis <demo@kukis.nl> # domain must be verified in Resend
